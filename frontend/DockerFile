# Local-development frontend image (served by Nginx on its own port,
# talking to a separately-running backend). For production single-service
# deployment (e.g. Koyeb free tier), use the root Dockerfile instead.
FROM node:20-alpine AS builder
WORKDIR /app

COPY package.json .
COPY package-lock.json .
RUN npm ci

COPY frontend/ .

# Cross-origin dev setup: point the frontend at the backend container's
# published port. Override with --build-arg if needed.
ARG REACT_APP_API_URL=http://localhost:8000
ENV REACT_APP_API_URL=$REACT_APP_API_URL
RUN npm run build

# Stage 2: Serve the app with a lightweight server
FROM nginx:1.27-alpine
COPY --from=builder /app/build /usr/share/nginx/html
COPY frontend/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
