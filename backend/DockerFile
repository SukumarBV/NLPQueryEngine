# Local-development / standalone backend image.
# For production single-service deployment (e.g. Koyeb free tier), use the
# root Dockerfile instead, which bundles the frontend too.
FROM python:3.11-slim
WORKDIR /app

COPY backend/requirements.txt requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY backend/ .
RUN rm -f .env

ENV PORT=8000
EXPOSE 8000

CMD ["sh", "-c", "uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000}"]
