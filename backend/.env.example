# Copy this file to .env for local (docker compose) development.
# On Koyeb, set these as Service environment variables/secrets instead
# of committing a real .env file.

# Connection string for your PostgreSQL database.
# Local docker-compose default (matches the `db` service below):
DATABASE_URL=postgresql://user:pass@db:5432/company_db

# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional overrides:
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# ALLOWED_ORIGINS=http://localhost:3000
